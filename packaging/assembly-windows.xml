<?xml version="1.0" encoding="UTF-8"?>
<!--
  Assembly descriptor for the Windows .zip fallback distribution.
  Mirrors the layout the jpackage installer creates:

      fresnel-<version>/
          bin/start-fresnel.bat
          lib/fresnel.jar
          config/application-standalone.properties
          README-install.md
-->
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0
                              http://maven.apache.org/xsd/assembly-2.2.0.xsd">
    <id>windows</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>fresnel-${project.version}</baseDirectory>

    <files>
        <file>
            <source>${project.build.directory}/${project.build.finalName}.jar</source>
            <outputDirectory>lib</outputDirectory>
            <destName>fresnel.jar</destName>
        </file>
    </files>

    <fileSets>
        <fileSet>
            <directory>${project.basedir}/../packaging/windows</directory>
            <outputDirectory>bin</outputDirectory>
            <includes>
                <include>start-fresnel.bat</include>
            </includes>
            <lineEnding>crlf</lineEnding>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../packaging/config</directory>
            <outputDirectory>config</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../packaging</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>README-install.md</include>
            </includes>
        </fileSet>
    </fileSets>
</assembly>
